{
    "name": "learninghub44/zetu",
    "description": "Official PHP SDK for Zetu WhatsApp API Gateway",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "whatsapp",
        "api",
        "sdk",
        "zetu",
        "gateway"
    ],
    "authors": [
        {
            "name": "Zetu Contributors"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Zetu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zetu\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}