# ============================================================
# OpenWA — Environment Variables
# Copy to .env for local dev. On Railway: set in Variables tab.
# NEVER commit a filled .env to git.
# ============================================================

# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_MASTER_KEY=CHANGE_ME_STRONG_RANDOM_SECRET_MIN_32_CHARS

# Server
NODE_ENV=production
PORT=2785

# Engine: baileys (no Chrome) or whatsapp-web.js (needs Chromium)
ENGINE_TYPE=baileys
BAILEYS_AUTH_DIR=./data/baileys
SESSION_DATA_PATH=./data/sessions

# Database — SQLite (default) or postgres
DATABASE_TYPE=sqlite
DATABASE_NAME=./data/openwa.sqlite
# DATABASE_TYPE=postgres
# DATABASE_HOST=your-pg.railway.internal
# DATABASE_PORT=5432
# DATABASE_USERNAME=openwa
# DATABASE_PASSWORD=strong_password
# DATABASE_NAME=openwa
# DATABASE_SSL=true

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/media
# STORAGE_TYPE=s3
# S3_BUCKET=openwa-media
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your-key
# S3_SECRET_ACCESS_KEY=your-secret
# S3_ENDPOINT=https://account.r2.cloudflarestorage.com

# Queue / Redis (optional)
QUEUE_ENABLED=false
REDIS_ENABLED=false
# QUEUE_ENABLED=true
# REDIS_HOST=your-redis.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# Security
CORS_ORIGINS=
TRUSTED_PROXIES=10.0.0.0/8

# Features
ENABLE_SWAGGER=true
LOG_LEVEL=info
PLUGINS_DIR=./data/plugins

# Webhooks
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5000

# ── Paystack Billing ──────────────────────────────────────────────────────────
# Get these from https://dashboard.paystack.com/#/settings/developer

# Your Paystack secret key (sk_live_... for production, sk_test_... for testing)
PAYSTACK_SECRET_KEY=sk_test_CHANGE_ME

# Your Paystack public key (used on frontend if needed)
PAYSTACK_PUBLIC_KEY=pk_test_CHANGE_ME

# Paystack Plan Codes — create these in Paystack Dashboard > Products > Plans
# Set billing period to Monthly and the amount to match the prices below:
#   Starter    → KES 1,500/month
#   Growth     → KES 3,500/month
#   Pro        → KES 7,000/month
#   Enterprise → KES 15,000/month
PAYSTACK_PLAN_STARTER=PLN_CHANGE_ME
PAYSTACK_PLAN_GROWTH=PLN_CHANGE_ME
PAYSTACK_PLAN_PRO=PLN_CHANGE_ME
PAYSTACK_PLAN_ENTERPRISE=PLN_CHANGE_ME

# Public base URL of your deployment (used for Paystack callback URLs and QR links)
BASE_URL=https://your-app.up.railway.app

# Multi-tenant automation
AUTO_START_SESSIONS=true
